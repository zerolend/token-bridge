{
  "exclude": ["node_modules"],
  "include": ["deploy", "tasks", "test", "typechain","scripts", "hardhat.config.ts"],
  "compilerOptions": {
    "target": "es2020",
    "module": "commonjs",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationDir": "./typechain"
  },
  "files": [
    "./hardhat.config.ts",
    "node_modules/@nomiclabs/hardhat-etherscan/src/type-extensions.ts",
    "node_modules/hardhat-gas-reporter/src/type-extensions.ts"
  ]
}
